@inherits LayoutComponentBase

<NavBar />

<style>
    body {
        display: flex;
        min-height: 100vh;
        flex-direction: column;
    }
    main {
        flex: 1 0 auto;
    }
</style>

<main>
    @Body
</main>

<footer class="page-footer orange darken-2" style="margin-top: 50px;">
    <div class="container">
        <div class="row">
            <div class="col s12 center-align">
                <h5 class="white-text">Good Burger</h5>
                <p class="grey-text text-lighten-4">Best burgers in town!</p>
            </div>
        </div>
    </div>
    <div class="footer-copyright">
        <div class="container center-align">
            Good Burger is a fictitious company for a development portfolio. Avaliable for download at <a href="https://github.com/FlaipyTheHost/GoodBurger">GitHub</a>.
        </div>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
