@page "/orders"
@using GoodBurger.Blazor.Models
@using GoodBurger.Blazor.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject GoodBurgerApiService ApiService
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Orders - Good Burger</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <div class="container" style="margin-top: 50px;">
            <div class="row">
                <div class="col s12">
                    <div class="card-panel orange lighten-4 center-align">
                        <i class="material-icons large orange-text text-darken-2">lock</i>
                        <h5 class="orange-text text-darken-2">Authentication Required</h5>
                        <p>You need to login to view orders.</p>
                        <a href="/login" class="btn orange darken-2 btn-large">
                            <i class="material-icons left">login</i>Login
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </NotAuthorized>
    <Authorized>
        <div class="container" style="margin-top: 30px;">
            <div class="row">
                <div class="col s12">
                    <h4 class="orange-text text-darken-2">
                        <i class="material-icons left">receipt_long</i>
                        All Orders
                    </h4>
                </div>
            </div>

            @if (isLoading)
            {
                <div class="row">
                    <div class="col s12 center-align">
                        <div class="preloader-wrapper big active">
                            <div class="spinner-layer spinner-orange-only">
                                <div class="circle-clipper left"><div class="circle"></div></div>
                                <div class="gap-patch"><div class="circle"></div></div>
                                <div class="circle-clipper right"><div class="circle"></div></div>
                            </div>
                        </div>
                    </div>
                </div>
            }
            else if (errorMessage != null)
            {
                <div class="row">
                    <div class="col s12">
                        <div class="card-panel red lighten-4">
                            <span class="red-text text-darken-2">
                                <i class="material-icons left">error</i>@errorMessage
                            </span>
                        </div>
                    </div>
                </div>
            }
            else if (orders == null || !orders.Any())
            {
                <div class="row">
                    <div class="col s12">
                        <div class="card-panel blue-grey lighten-5">
                            <span class="blue-grey-text text-darken-2">
                                <i class="material-icons left">info</i>No orders found. Make your first order!
                            </span>
                        </div>
                        <a href="/new-order" class="btn waves-effect waves-light orange darken-2 btn-large">
                            <i class="material-icons left">add</i>New Order
                        </a>
                    </div>
                </div>
            }
            else
            {
                <div class="row">
                    <div class="col s12">
                        <p class="grey-text">Total orders: @totalOrders</p>
                    </div>
                </div>

                @foreach (var order in orders.OrderByDescending(o => o.CreatedAt))
                {
                    <div class="row">
                        <div class="col s12">
                            <div class="card">
                                <div class="card-content">
                                    <div class="row" style="margin-bottom: 0;">
                                        <div class="col s12 m8">
                                            <span class="card-title orange-text text-darken-2">
                                                Order #@order.Id.ToString().Substring(0, 8)
                                            </span>
                                            <p class="grey-text text-darken-1">
                                                <i class="material-icons tiny">access_time</i>
                                                @order.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
                                            </p>
                                        </div>
                                        <div class="col s12 m4 right-align">
                                            <h5 class="orange-text text-darken-2" style="margin-top: 10px;">
                                                R$ @order.Total.ToString("F2")
                                            </h5>
                                        </div>
                                    </div>

                                    <table class="striped" style="margin-top: 15px;">
                                        <tbody>
                                            <tr>
                                                <td><i class="material-icons tiny orange-text">fastfood</i> <strong>Sandwich:</strong></td>
                                                <td>@order.Sandwich</td>
                                            </tr>
                                            <tr>
                                                <td><i class="material-icons tiny orange-text">@(order.HasFries ? "check_box" : "check_box_outline_blank")</i> <strong>Fries:</strong></td>
                                                <td>@(order.HasFries ? "Yes" : "No")</td>
                                            </tr>
                                            <tr>
                                                <td><i class="material-icons tiny orange-text">@(order.HasSoda ? "check_box" : "check_box_outline_blank")</i> <strong>Soda:</strong></td>
                                                <td>@(order.HasSoda ? "Yes" : "No")</td>
                                            </tr>
                                            <tr>
                                                <td><strong>Subtotal:</strong></td>
                                                <td>R$ @order.Subtotal.ToString("F2")</td>
                                            </tr>
                                            @if (order.DiscountPercent > 0)
                                            {
                                                <tr class="green-text">
                                                    <td><i class="material-icons tiny">local_offer</i> <strong>Discount (@order.DiscountPercent%):</strong></td>
                                                    <td><strong>- R$ @order.Discount.ToString("F2")</strong></td>
                                                </tr>
                                            }
                                            <tr class="orange darken-2 white-text">
                                                <td><strong>TOTAL PAID:</strong></td>
                                                <td><strong>R$ @order.Total.ToString("F2")</strong></td>
                                            </tr>
                                        </tbody>
                                    </table>
                                </div>
                                <div class="card-action">
                                    <button class="btn-small waves-effect waves-light red darken-1"
                                            @onclick="() => DeleteOrder(order.Id)"
                                            disabled="@isDeleting">
                                        <i class="material-icons left">delete</i>Delete
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                }

                <div class="row">
                    <div class="col s12">
                        <a href="/new-order" class="btn waves-effect waves-light orange darken-2 btn-large">
                            <i class="material-icons left">add</i>New Order
                        </a>
                    </div>
                </div>
            }
        </div>
    </Authorized>
</AuthorizeView>

@code {
    private List<OrderResponse>? orders;
    private int totalOrders;
    private bool isLoading = true;
    private bool isDeleting = false;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadOrders();
    }

    private async Task LoadOrders()
    {
        isLoading = true;
        errorMessage = null;
        try
        {
            var response = await ApiService.GetOrdersAsync(page: 1, pageSize: 100);
            if (response != null)
            {
                orders = response.Items.ToList();
                totalOrders = response.TotalCount;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error loading orders: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task DeleteOrder(Guid orderId)
    {
        if (!await JSRuntime.InvokeAsync<bool>("confirm", "Are you sure you want to delete this order?"))
            return;

        isDeleting = true;
        errorMessage = null;
        try
        {
            await ApiService.DeleteOrderAsync(orderId);
            await LoadOrders();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error deleting order: {ex.Message}";
        }
        finally
        {
            isDeleting = false;
        }
    }
}